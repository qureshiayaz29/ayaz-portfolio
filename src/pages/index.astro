---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Ayaz Qureshi – Android & Flutter Developer. I craft mobile experiences that scale beautifully." />
    <meta name="theme-color" content="#FFF9E9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href="https://ayazqureshi.vercel.app/" />
    <meta property="og:title" content="Ayaz Qureshi – Android & Flutter Developer" />
    <meta property="og:description" content="I craft mobile experiences that scale beautifully." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ayazqureshi.vercel.app/" />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:site_name" content="Ayaz Qureshi Portfolio" />
    <meta property="og:image:alt" content="Ayaz Qureshi portfolio preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Ayaz Qureshi – Android & Flutter Developer" />
    <meta name="twitter:description" content="I craft mobile experiences that scale beautifully." />
    <meta name="twitter:image" content="/favicon.svg" />
    <meta name="author" content="Ayaz Qureshi" />
    <meta name="application-name" content="Ayaz Qureshi Portfolio" />
    <meta name="robots" content="index,follow" />
    <meta name="color-scheme" content="light" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Nunito:wght@400;700&family=Poppins:wght@400;700&display=swap" />
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/poppins/v20/pxiByp8kv8JHgFVrLDz8Z11lFQ.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/inter/v13/UcCO3FAm8S66w7cizQ.woff2" type="font/woff2" crossorigin />
    <title>Ayaz Qureshi – Android & Flutter Developer</title>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ayaz Qureshi",
        "jobTitle": "Android & Flutter Developer",
        "url": "https://ayazqureshi.vercel.app/",
        "sameAs": [
          "https://www.youtube.com/@ayazqureshi",
          "https://medium.com/@ayazqureshi",
          "https://www.linkedin.com/in/ayazqureshi/"
        ]
      }
    </script>
  </head>
  <body class="bg-offwhite font-poppins w-screen">
    <a href="#content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-indigo-600 text-white px-4 py-2 rounded">Skip to content</a>
    <main id="content" role="main" class="min-h-[100svh] md:min-h-[100dvh] w-full flex flex-col md:flex-row items-center justify-center px-4 md:px-12 gap-10 md:gap-20 content-shell py-2 md:py-6 pb-4">
      <!-- Person Avatar Illustration (Clean, Professional) -->
      <div class="flex items-center justify-center avatar-wrapper" aria-hidden="true">
        <div class="avatar-size">
          <!-- Retro Mobile Avatar SVG -->
          <svg viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="panelGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#ffffff" />
                <stop offset="100%" stop-color="#f3f4f6" />
              </linearGradient>
              <linearGradient id="phoneBody" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1f2937" />
                <stop offset="100%" stop-color="#111827" />
              </linearGradient>
              <linearGradient id="screenGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#064e3b" />
                <stop offset="100%" stop-color="#047857" />
              </linearGradient>
              <linearGradient id="accentGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#6366F1" />
                <stop offset="100%" stop-color="#8B5CF6" />
              </linearGradient>
            </defs>
            <!-- Background panel -->
            <rect x="0" y="0" width="240" height="240" rx="28" fill="url(#panelGrad)" stroke="#e2e8f0" />
            <!-- Shadow oval -->
            <ellipse cx="120" cy="190" rx="70" ry="18" fill="#000" opacity="0.06" />
            <!-- Phone body -->
            <rect x="78" y="46" width="84" height="148" rx="18" fill="url(#phoneBody)" stroke="#0f172a" stroke-width="3" />
            <!-- Antenna (retro touch) -->
            <rect x="116" y="28" width="8" height="18" rx="4" fill="#374151" />
            <circle cx="120" cy="24" r="6" fill="#4f46e5" />
            <!-- Screen -->
            <rect x="90" y="62" width="60" height="72" rx="6" fill="url(#screenGrad)" stroke="#065f46" stroke-width="2" />
            <!-- Pixel code lines on screen -->
            <rect x="98" y="72" width="44" height="8" rx="2" fill="#10b981" opacity="0.9" />
            <rect x="98" y="84" width="36" height="6" rx="2" fill="#34d399" opacity="0.85" />
            <rect x="98" y="94" width="42" height="6" rx="2" fill="#6ee7b7" opacity="0.85" />
            <rect x="98" y="104" width="28" height="6" rx="2" fill="#34d399" opacity="0.85" />
            <rect x="98" y="114" width="38" height="6" rx="2" fill="#10b981" opacity="0.9" />
            <!-- Speaker slot -->
            <rect x="106" y="54" width="28" height="4" rx="2" fill="#374151" />
            <!-- Navigation buttons area -->
            <rect x="90" y="142" width="60" height="36" rx="10" fill="#1f2937" stroke="#374151" stroke-width="2" />
            <!-- D-pad circle -->
            <circle cx="120" cy="160" r="14" fill="#111827" stroke="#4f46e5" stroke-width="2" />
            <rect x="119" y="150" width="2" height="20" fill="#4f46e5" />
            <rect x="110" y="159" width="20" height="2" fill="#4f46e5" />
            <!-- Side accent stripe -->
            <rect x="78" y="46" width="8" height="148" rx="4" fill="url(#accentGrad)" />
          </svg>
        </div>
      </div>
      <!-- Content Column -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left gap-4 max-w-xl content-column">
        <h1 class="title-main font-bold tracking-tight text-[#1f2937]">Hi, I’m Ayaz Qureshi</h1>
        <h2 class="title-sub font-semibold text-[#374151]">Android & Flutter Developer</h2>
        <p class="title-tagline text-[#1f2937]">I craft mobile experiences that perform and scale elegantly.</p>
        <p class="para-long text-[#374151] leading-relaxed">I’m a mobile engineer who enjoys building products end-to-end — from architecture and system design to crafting smooth, delightful UIs. I’ve collaborated with global teams to ship reliable, human-centered apps. Beyond code, I write blogs on Medium, share tech insights on YouTube, and build playful tools like my Telegram bot to automate everyday ideas.</p>
        <div class="flex flex-row gap-3 mt-2 shrink-links" id="links">
          <a href="https://www.youtube.com/insideandroid" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="flex items-center justify-center p-2 rounded-md border border-[#d1d5db] hover:border-[#9ca3af] transition-colors focus:outline-none focus:ring-2 focus:ring-red-300">
            <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="16" cy="16" r="16" fill="#FF0000" />
              <polygon points="14,10 22,16 14,22" fill="#FFFFFF" />
            </svg>
          </a>
          <a href="https://qureshi-ayaz29.medium.com/" target="_blank" rel="noopener noreferrer" aria-label="Medium" class="flex items-center justify-center p-2 rounded-md border border-[#d1d5db] hover:border-[#9ca3af] transition-colors focus:outline-none focus:ring-2 focus:ring-gray-400">
            <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="16" cy="16" r="16" fill="#000000" />
              <text x="16" y="16" text-anchor="middle" dominant-baseline="central" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#FFFFFF">M</text>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/ayazqureshi29/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex items-center justify-center p-2 rounded-md border border-[#d1d5db] hover:border-[#9ca3af] transition-colors focus:outline-none focus:ring-2 focus:ring-blue-300">
            <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="16" cy="16" r="16" fill="#0A66C2" />
              <text x="16" y="16" text-anchor="middle" dominant-baseline="central" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#FFFFFF">L</text>
            </svg>
          </a>
        </div>
        <div class="flex flex-wrap justify-start gap-2 mt-3 text-sm md:text-base skills-row">
          <span class="px-4 py-2 rounded-full bg-[#eef0f3] text-[#1f2937] font-medium">Android</span>
          <span class="px-4 py-2 rounded-full bg-[#eef0f3] text-[#1f2937] font-medium">Kotlin</span>
          <span class="px-4 py-2 rounded-full bg-[#eef0f3] text-[#1f2937] font-medium">Java</span>
          <span class="px-4 py-2 rounded-full bg-[#eef0f3] text-[#1f2937] font-medium">Flutter</span>
          <span class="px-4 py-2 rounded-full bg-[#eef0f3] text-[#1f2937] font-medium">Python</span>
        </div>
        <div class="flex flex-row flex-wrap gap-4 mt-4 friendly-links">
          <div class="flex flex-col items-start gap-1 links-block">
            <h3 class="text-xs font-medium tracking-wide uppercase text-[#6b7280]">Some friendly links</h3>
            <a href="https://parsejsononline.com" target="_blank" rel="noopener noreferrer" class="text-[#374151] hover:underline text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">Parse JSON Online</a>
            <a href="https://insideandroid.in" target="_blank" rel="noopener noreferrer" class="text-[#374151] hover:underline text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">Inside Android (Coming soon)</a>
          </div>
        </div>
      </div>
    </main>
    <style>
      /* Responsive scaling with clamps */
      .title-main { font-size: clamp(1.9rem, 5.2vw, 3.2rem); line-height: 1.1; }
      .title-sub { font-size: clamp(1rem, 2.2vw, 1.35rem); }
      .title-tagline { font-size: clamp(0.95rem, 2.1vw, 1.2rem); }
      .para-long { font-size: clamp(0.82rem, 1.9vw, 0.95rem); }
      .avatar-size { width: clamp(160px, 26vh, 256px); height: clamp(160px, 26vh, 256px); }
      .content-shell { gap: clamp(1.25rem, 3vh, 2.5rem); }

      @media (max-height: 780px) { .avatar-size { width: clamp(150px, 24vh, 220px); height: clamp(150px, 24vh, 220px); } .para-long { max-width:48ch; } }
      @media (max-height: 700px) { .avatar-size { width: clamp(130px,22vh,200px); height: clamp(130px,22vh,200px); } .para-long { font-size:0.78rem; } .content-shell { gap:1.1rem; } }
      @media (max-height: 640px) { .avatar-size { width: clamp(120px,20vh,180px); height: clamp(120px,20vh,180px); } .title-main { font-size: clamp(1.5rem,5vw,2.2rem);} .title-sub { font-size: clamp(.85rem,2vw,1.05rem);} .para-long { display:none; } .skills-row { gap:.35rem; } }

      /* Compress but keep links visible */
      @media (max-height: 560px) {
        body { overflow-y:auto; }
        .avatar-size { width:100px; height:100px; }
        .title-main { font-size:1.35rem; }
        .title-sub { font-size:0.8rem; }
        .title-tagline { font-size:0.72rem; }
        .skills-row span { padding:0.3rem 0.55rem; font-size:0.62rem; }
        .content-column { gap:0.55rem; }
        .friendly-links { margin-top:0.4rem; }
        .links-block { display:flex; flex-wrap:wrap; align-items:center; }
        .links-block h3 { flex-basis:100%; margin:0 0 2px; }
        .links-block a { margin-right:0.5rem; }
        .links-block a:last-child { display:inline; }
      }

      @media (max-height: 500px) {
        .avatar-wrapper { display:none; }
        .title-main { font-size:1.25rem; }
        .title-sub { font-size:0.75rem; }
        .title-tagline { font-size:0.65rem; }
        .skills-row { flex-wrap:wrap; }
        .skills-row span { font-size:0.58rem; }
        .friendly-links { margin-top:0.35rem; }
      }

      /* Fold / landscape narrow height */
      @media (min-width:700px) and (max-height:600px) { .avatar-size { width:90px; height:90px; } }
    </style>
  </body>
</html>
