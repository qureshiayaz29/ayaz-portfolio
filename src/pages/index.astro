---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import SkillGroup from '../components/SkillGroup.astro';
import ExpCard from '../components/ExpCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { experiences } from '../data/experience';
import { projects } from '../data/projects';
import { SITE_URL } from '../site.config.mjs';
import Analytics from '@vercel/analytics/astro';

const featuredProjectNames = ['Antigravity Toolkit', 'NIFTY Options Trading Bot', 'Tez Billing'];
const featuredProjects = featuredProjectNames
  .map(name => projects.find(p => p.name === name))
  .filter(Boolean);

const channels = [
  { label: 'LinkedIn', url: 'https://www.linkedin.com/in/ayazqureshi29/' },
  { label: 'Medium',   url: 'https://qureshi-ayaz29.medium.com/' },
  { label: 'YouTube',  url: 'https://www.youtube.com/@InsideAndroid' },
  { label: 'GitHub',   url: 'https://github.com/qureshiayaz29' },
];

const websites = [
  { name: 'Parse JSON Online', url: 'https://parsejsononline.com', domain: 'parsejsononline.com' },
  { name: 'Tez Billing',       url: 'https://tezbilling.com',      domain: 'tezbilling.com' },
  { name: 'ResumeFit Bot',     url: 'https://t.me/ResumeFitBot',   domain: 't.me/ResumeFitBot' },
];

const skillGroups = [
  {
    title: "Mobile Engineering",
    borderColor: "#1D9E75",
    tagBg: "rgba(29,158,117,0.1)",
    tagColor: "#34d399",
    tags: [
      "Android SDK", "Kotlin", "Java", "Jetpack Compose", "Flutter", "Dart",
      "KMM", "Room DB", "WorkManager", "Paging 3", "Navigation Component",
      "Material Design 3", "Lifecycle", "ProGuard/R8"
    ],
    context: "Built and scaled production Android apps serving tens of millions of users. Deep in architecture, performance optimisation, and smooth UI delivery."
  },
  {
    title: "Architecture & Design",
    borderColor: "#6366f1",
    tagBg: "rgba(99,102,241,0.1)",
    tagColor: "#818cf8",
    tags: [
      "MVVM", "Clean Architecture", "SOLID", "TDD", "Dagger/Hilt", "Koin",
      "Coroutines", "Flow", "StateFlow", "LiveData", "DataStore",
      "Retrofit", "Modular Design"
    ],
    context: "Owned architecture decisions end-to-end. Introduced patterns that reduced onboarding time and improved test coverage across teams."
  },
  {
    title: "Backend & Web",
    borderColor: "#8b5cf6",
    tagBg: "rgba(139,92,246,0.1)",
    tagColor: "#a78bfa",
    tags: [
      "Python", "FastAPI", "Node.js", "TypeScript", "Firebase",
      "PostgreSQL", "Redis", "Docker", "Astro", "Fly.io",
      "Vercel", "DigitalOcean", "REST APIs", "Nginx"
    ],
    context: "Ships full products end-to-end — web frontends, backend services, and cloud deployments. Comfortable owning infra as a solo builder."
  },
  {
    title: "AI & Automation",
    borderColor: "#f59e0b",
    tagBg: "rgba(245,158,11,0.1)",
    tagColor: "#fbbf24",
    tags: [
      "OpenAI APIs", "LangChain", "LLM Integration", "Prompt Engineering",
      "RAG", "Vector Databases", "Telegram Bots", "Algo Trading",
      "Whisper API", "Reportlab", "Fine-tuning"
    ],
    context: "Built AI-powered bots, recommendation systems, and trading automation. Comfortable wiring LLMs into real products, not just demos."
  },
  {
    title: "Observability & Quality",
    borderColor: "#ef4444",
    tagBg: "rgba(239,68,68,0.1)",
    tagColor: "#f87171",
    tags: [
      "Firebase Crashlytics", "Mixpanel", "Datadog", "Sentry",
      "ktlint", "detekt", "JaCoCo", "LeakCanary",
      "Espresso", "Mockito", "Unit Testing", "A/B Testing"
    ],
    context: "Maintained crash-free rates at scale. Introduced static analysis tooling that reduced code review time and improved reliability."
  },
  {
    title: "DevOps & Tooling",
    borderColor: "#06b6d4",
    tagBg: "rgba(6,182,212,0.1)",
    tagColor: "#22d3ee",
    tags: [
      "Jenkins CI/CD", "GitHub Actions", "Gradle", "Git",
      "Play Console", "Firebase App Distribution",
      "Jira", "Bitbucket", "Branch.io", "Android Studio", "Cursor IDE"
    ],
    context: "End-to-end release ownership — from pre-release analysis and CI/CD pipelines to zero-issue production rollouts."
  }
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Ayaz Qureshi",
  "jobTitle": "Builder & Indie Developer",
  "url": SITE_URL + '/',
  "sameAs": [
    "https://www.youtube.com/@InsideAndroid",
    "https://qureshi-ayaz29.medium.com/",
    "https://www.linkedin.com/in/ayazqureshi29/",
    "https://github.com/qureshiayaz29"
  ]
});
---

<Base
  title="Ayaz Qureshi — Builder & Indie Developer"
  description="Android engineer and indie builder. I ship tools, apps, and automation — end to end."
  canonical="/"
>
  <script slot="head" type="application/ld+json" set:html={jsonLd}></script>

  <Nav />

  <main id="content" class="max-w-3xl mx-auto px-6">

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="pt-16 pb-16">
      <p style="font-family:'DM Mono',monospace; font-size:12px; text-transform:uppercase; letter-spacing:0.1em; color:#525252;">
        Ayaz Qureshi — Bangalore, India
      </p>

      <h1 style="font-family:'Instrument Serif',serif; font-size:clamp(2.8rem,7vw,4.5rem); line-height:1.05; color:#f0f0f0; margin-top:14px;">
        Builder.<br />
        <em style="font-style:italic; color:#1D9E75;">Indie Developer.</em>
      </h1>

      <p style="font-family:'Geist',sans-serif; font-size:16px; color:#737373; max-width:52ch; line-height:1.75; margin-top:22px;">
        I ship products end-to-end — from architecture and system design to delightful UIs.
        Mobile-first, but increasingly building for web, AI, and automation. Currently working
        on a handful of tools and platforms in parallel.
      </p>

      <!-- Find me on -->
      <p style="font-family:'DM Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.1em; color:#525252; margin-top:28px; margin-bottom:10px;">
        Find me on
      </p>
      <div class="flex flex-wrap gap-2">
        {channels.map(c => (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="channel-pill"
            style="font-family:'Geist',sans-serif; font-size:13px; font-weight:500; border:1px solid #2e2e2e; border-radius:9999px; padding:7px 16px; color:#d4d4d4; text-decoration:none;"
          >{c.label}</a>
        ))}
      </div>

      <!-- Things I've built -->
      <p style="font-family:'DM Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.1em; color:#525252; margin-top:24px; margin-bottom:10px;">
        Things I've built
      </p>
      <div class="flex flex-wrap gap-3">
        {websites.map(w => (
          <a
            href={w.url}
            target="_blank"
            rel="noopener noreferrer"
            class="website-link"
            style="border:1px solid #2e2e2e; border-radius:10px; padding:11px 16px; text-decoration:none; display:flex; flex-direction:column; gap:3px; min-width:150px;"
          >
            <span style="font-family:'Geist',sans-serif; font-size:14px; font-weight:500; color:#d4d4d4;">{w.name}</span>
            <span style="font-family:'DM Mono',monospace; font-size:11px; color:#525252;">{w.domain} ↗</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Skills ────────────────────────────────────────────────────── -->
    <section class="pb-16">
      <p style="font-family:'DM Mono',monospace; font-size:12px; text-transform:uppercase; letter-spacing:0.12em; color:#525252; margin-bottom:20px;">
        Skills &amp; expertise
      </p>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px;">
        {skillGroups.map(sg => (
          <SkillGroup
            title={sg.title}
            tags={sg.tags}
            context={sg.context}
            borderColor={sg.borderColor}
            tagBg={sg.tagBg}
            tagColor={sg.tagColor}
          />
        ))}
      </div>
    </section>

    <!-- ── Experience ────────────────────────────────────────────────── -->
    <section class="pb-16">
      <p style="font-family:'DM Mono',monospace; font-size:12px; text-transform:uppercase; letter-spacing:0.12em; color:#525252; margin-bottom:16px;">
        Professional work
      </p>

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-2 mb-5">
        <button class="filter-btn active" data-exp-filter="all">All</button>
        <button class="filter-btn" data-exp-filter="fintech">Fintech</button>
        <button class="filter-btn" data-exp-filter="mobility">Mobility</button>
        <button class="filter-btn" data-exp-filter="enterprise">Enterprise</button>
      </div>

      <!-- Experience cards -->
      <div class="flex flex-col gap-3">
        {experiences.map(exp => (
          <ExpCard
            domain={exp.domain}
            domainLabel={exp.domainLabel}
            role={exp.role}
            title={exp.title}
            tenure={exp.tenure}
            scale={exp.scale}
            stack={exp.stack}
            highlights={exp.highlights}
          />
        ))}
      </div>
    </section>

    <!-- ── Featured Projects ─────────────────────────────────────────── -->
    <section class="pb-20">
      <div class="flex items-center justify-between mb-5">
        <p style="font-family:'DM Mono',monospace; font-size:12px; text-transform:uppercase; letter-spacing:0.12em; color:#525252;">
          Featured projects
        </p>
        <a
          href="/projects"
          class="see-all-link"
          style="font-family:'Geist',sans-serif; font-size:14px; color:#1D9E75; text-decoration:none;"
        >See all →</a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:14px;">
        {featuredProjects.map(p => p && (
          <ProjectCard
            name={p.name}
            cat={p.cat}
            catLabel={p.catLabel}
            status={p.status}
            desc={p.desc}
            what={p.what}
            stack={p.stack}
            next={p.next}
            link={p.link}
            featured={true}
          />
        ))}
      </div>
    </section>

  </main>

  <script>
    // Experience filter
    const expFilterBtns = document.querySelectorAll<HTMLButtonElement>('[data-exp-filter]');
    expFilterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const domain = btn.dataset.expFilter ?? 'all';
        document.querySelectorAll<HTMLElement>('.exp-card').forEach(card => {
          card.style.display = (domain === 'all' || card.dataset.domain === domain) ? '' : 'none';
        });
        expFilterBtns.forEach(b => b.classList.toggle('active', b === btn));
      });
    });

    // Expand / collapse
    document.querySelectorAll<HTMLElement>('.expandable-card').forEach(card => {
      card.addEventListener('click', e => {
        if ((e.target as Element).closest('a')) return;
        card.classList.toggle('expanded');
      });
    });
  </script>

  <style>
    .channel-pill:hover { background: #1a1a1a; border-color: #3a3a3a; }
    .see-all-link:hover { text-decoration: underline; }
    .website-link:hover {
      border-color: #1D9E75 !important;
      background: rgba(29,158,117,0.04);
    }
  </style>
</Base>
