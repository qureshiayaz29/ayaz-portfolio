---
import '../styles/global.css';
import { SITE_URL } from '../site.config.mjs';
import Analytics from '@vercel/analytics/astro';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>Page Not Found – Ayaz Qureshi</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={SITE_URL + '/'} />
    <meta property="og:title" content="404 – Ayaz Qureshi" />
    <meta property="og:description" content="Page not found" />
    <meta property="og:url" content={SITE_URL + '/'} />
    <meta property="og:image" content={SITE_URL + '/og-image.svg'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={SITE_URL + '/favicon.svg'} />
    <Analytics />
  </head>
  <body class="bg-offwhite font-poppins flex items-center justify-center min-h-screen p-6 text-center">
    <div class="max-w-md">
      <h1 class="text-3xl font-bold mb-4 text-[#1f2937]">404 – Not Found</h1>
      <p class="text-[#374151] mb-6">The page you’re looking for doesn’t exist. Return to the homepage to explore my work.</p>
      <a href="/" class="inline-block px-6 py-3 rounded-full bg-indigo-600 text-white font-semibold shadow-soft hover:bg-indigo-500 focus:outline-none focus:ring-4 focus:ring-indigo-300">Go Home</a>
    </div>
  </body>
</html>
