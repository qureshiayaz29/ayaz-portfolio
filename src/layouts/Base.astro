---
import '../styles/global.css';
import { SITE_URL } from '../site.config.mjs';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical = '/', noindex = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0c0c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={SITE_URL + canonical} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <meta name="color-scheme" content="dark" />
    <meta name="author" content="Ayaz Qureshi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL + canonical} />
    <meta property="og:image" content={SITE_URL + '/og-image.svg'} />
    <meta property="og:site_name" content="Ayaz Qureshi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={SITE_URL + '/og-image.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@400;500&family=Geist:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
    <style>
      body { height: auto !important; min-height: 100dvh; overflow-y: auto; }
    </style>
  </head>
  <body style="background:#0c0c0c;">

    <!-- Ambient glow layer (CSS orbs for depth) -->
    <div class="orb-container" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <!-- Particle canvas (sits above orbs, below content) -->
    <canvas
      id="bg-canvas"
      aria-hidden="true"
      style="position:fixed; inset:0; z-index:1; pointer-events:none; width:100%; height:100%;"
    ></canvas>

    <!-- Page content -->
    <div style="position:relative; z-index:2;">
      <a
        href="#content"
        class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:rounded focus:text-white"
        style="background:#1D9E75"
      >Skip to content</a>
      <slot />
    </div>

    <script>
      const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      let W = 0, H = 0;
      const mouse = { x: -9999, y: -9999 };

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // Track mouse
      window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
      window.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
      // Touch support
      window.addEventListener('touchmove', e => {
        mouse.x = e.touches[0].clientX;
        mouse.y = e.touches[0].clientY;
      }, { passive: true });
      window.addEventListener('touchend', () => { mouse.x = -9999; mouse.y = -9999; });

      const isMobile = window.innerWidth < 768;
      const COUNT    = isMobile ? 38 : 68;
      const MAX_DIST = 145;
      const MOUSE_R  = 130;
      const SPEED    = 0.38;

      interface Pt {
        x: number; y: number;
        vx: number; vy: number;
        r: number; baseA: number; phase: number;
      }

      const pts: Pt[] = Array.from({ length: COUNT }, () => ({
        x: Math.random() * window.innerWidth,
        y: Math.random() * window.innerHeight,
        vx: (Math.random() - 0.5) * SPEED,
        vy: (Math.random() - 0.5) * SPEED,
        r: Math.random() * 1.4 + 0.5,
        baseA: Math.random() * 0.3 + 0.15,
        phase: Math.random() * Math.PI * 2,
      }));

      let frame = 0;

      function d2(ax: number, ay: number, bx: number, by: number) {
        const dx = ax - bx, dy = ay - by;
        return Math.sqrt(dx * dx + dy * dy);
      }

      function tick() {
        ctx.clearRect(0, 0, W, H);
        frame++;

        // Move particles
        for (const p of pts) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0)  { p.vx =  Math.abs(p.vx); }
          if (p.x > W)  { p.vx = -Math.abs(p.vx); }
          if (p.y < 0)  { p.vy =  Math.abs(p.vy); }
          if (p.y > H)  { p.vy = -Math.abs(p.vy); }
        }

        // Particle-to-particle connections
        for (let i = 0; i < pts.length; i++) {
          for (let j = i + 1; j < pts.length; j++) {
            const dist = d2(pts[i].x, pts[i].y, pts[j].x, pts[j].y);
            if (dist >= MAX_DIST) continue;

            const nearMouse =
              d2(pts[i].x, pts[i].y, mouse.x, mouse.y) < MOUSE_R ||
              d2(pts[j].x, pts[j].y, mouse.x, mouse.y) < MOUSE_R;

            const t = 1 - dist / MAX_DIST;
            const alpha = nearMouse ? t * 0.45 : t * 0.1;

            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.strokeStyle = `rgba(29,158,117,${alpha})`;
            ctx.lineWidth = nearMouse ? 0.9 : 0.5;
            ctx.stroke();
          }
        }

        // Mouse-to-nearby lines
        if (mouse.x > 0) {
          for (const p of pts) {
            const dist = d2(p.x, p.y, mouse.x, mouse.y);
            if (dist < MOUSE_R) {
              const t = 1 - dist / MOUSE_R;
              ctx.beginPath();
              ctx.moveTo(mouse.x, mouse.y);
              ctx.lineTo(p.x, p.y);
              ctx.strokeStyle = `rgba(29,158,117,${t * 0.35})`;
              ctx.lineWidth = 0.7;
              ctx.stroke();
            }
          }
        }

        // Draw dots
        for (const p of pts) {
          const md = d2(p.x, p.y, mouse.x, mouse.y);
          const nearMouse = md < MOUSE_R;
          const pulse = Math.sin(frame * 0.018 + p.phase) * 0.12 + 0.88;
          const radius = p.r * (nearMouse ? 2.4 : 1.0) * pulse;
          const alpha  = nearMouse ? 0.9 : p.baseA * pulse;

          // Outer glow for mouse-near dots
          if (nearMouse) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, radius * 3.5, 0, Math.PI * 2);
            const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, radius * 3.5);
            grd.addColorStop(0, 'rgba(29,158,117,0.12)');
            grd.addColorStop(1, 'rgba(29,158,117,0)');
            ctx.fillStyle = grd;
            ctx.fill();
          }

          ctx.beginPath();
          ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(29,158,117,${alpha})`;
          ctx.fill();
        }

        requestAnimationFrame(tick);
      }

      tick();
    </script>
  </body>
</html>
