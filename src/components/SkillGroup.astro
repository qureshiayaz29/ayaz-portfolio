---
interface Props {
  title: string;
  tags: string[];
  context: string;
  borderColor?: string;
  tagBg?: string;
  tagColor?: string;
}
const {
  title,
  tags,
  context,
  borderColor = '#333',
  tagBg = '#1f1f1f',
  tagColor = '#a3a3a3'
} = Astro.props;
---

<div style={`border:1px solid #242424; border-left:3px solid ${borderColor}; border-radius:12px; padding:20px; background:#161616;`}>
  <h3 style="font-family:'Geist',sans-serif; font-size:15px; font-weight:500; color:#f0f0f0; margin:0;">{title}</h3>
  <div class="flex flex-wrap gap-1.5 mt-3">
    {tags.map(tag => (
      <span style={`font-family:'DM Mono',monospace; font-size:12px; background:${tagBg}; color:${tagColor}; padding:3px 9px; border-radius:4px; font-weight:500;`}>{tag}</span>
    ))}
  </div>
  <p style="font-family:'Geist',sans-serif; font-size:14px; color:#737373; margin-top:14px; line-height:1.65;">{context}</p>
</div>
