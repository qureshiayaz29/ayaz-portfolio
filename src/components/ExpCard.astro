---
interface Props {
  domain: string;
  domainLabel: string;
  role: string;
  title: string;
  tenure: string;
  scale: string;
  stack: string[];
  highlights: string[];
}

const { domain, domainLabel, role, title, tenure, scale, stack, highlights } = Astro.props;
---

<div
  class="exp-card expandable-card"
  data-domain={domain}
  style="border:1px solid #242424; border-radius:12px; padding:20px; background:#161616; cursor:pointer; transition:border-color 0.15s;"
  onmouseover="this.style.borderColor='#333'"
  onmouseout="this.style.borderColor='#242424'"
>
  <div class="flex items-start justify-between gap-3">
    <div style="flex:1; min-width:0;">
      <p style="font-family:'Geist',sans-serif; font-size:15px; font-weight:500; color:#f0f0f0; margin:0;">{role}</p>
      <div class="flex items-center gap-2 flex-wrap mt-2">
        <span style="font-family:'DM Mono',monospace; font-size:11px; background:#1f1f1f; color:#a3a3a3; padding:3px 9px; border-radius:4px;">{domainLabel}</span>
        <span style="font-family:'DM Mono',monospace; font-size:12px; color:#525252;">{tenure}</span>
      </div>
      <p style="font-family:'Geist',sans-serif; font-size:14px; color:#737373; margin-top:10px;">
        {title} <span style="color:#525252;">— {scale}</span>
      </p>
    </div>
    <span
      class="expand-icon"
      style="font-family:'DM Mono',monospace; font-size:18px; color:#525252; line-height:1; width:20px; text-align:center; flex-shrink:0; margin-top:2px;"
    ></span>
  </div>
  <div class="detail" style="margin-top:18px; padding-top:18px; border-top:1px solid #222;">
    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
      {highlights.map(h => (
        <li style="display:flex; gap:10px; font-family:'Geist',sans-serif; font-size:14px; color:#a3a3a3; line-height:1.65;">
          <span style="color:#333; flex-shrink:0; margin-top:2px;">•</span>
          <span>{h}</span>
        </li>
      ))}
    </ul>
    <div class="flex flex-wrap gap-1.5 mt-5">
      {stack.map(tag => (
        <span style="font-family:'DM Mono',monospace; font-size:12px; background:#1f1f1f; color:#737373; padding:3px 9px; border-radius:4px;">{tag}</span>
      ))}
    </div>
  </div>
</div>
