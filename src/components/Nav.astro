---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
const isProjects = currentPath.startsWith('/projects');
---

<nav style="position:sticky; top:0; z-index:10; border-bottom:1px solid #1f1f1f; background:rgba(12,12,12,0.92); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);">
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-1 hover:opacity-70 transition-opacity" aria-label="Ayaz Qureshi — home">
      <span style="font-family:'DM Mono',monospace; font-size:14px; color:#f0f0f0; font-weight:500;">AQ</span>
      <span style="color:#1D9E75; font-size:10px; line-height:1;">●</span>
    </a>

    <!-- Right side -->
    <div class="flex items-center gap-5">
      <a
        href="/"
        style={`font-family:'Geist',sans-serif; font-size:15px; text-decoration:none; transition:color 0.15s; color:${isHome ? '#f0f0f0' : '#525252'};`}
        onmouseover={!isHome ? "this.style.color='#a3a3a3'" : ''}
        onmouseout={!isHome ? "this.style.color='#525252'" : ''}
      >home</a>
      <a
        href="/projects"
        style={`font-family:'Geist',sans-serif; font-size:15px; text-decoration:none; transition:color 0.15s; color:${isProjects ? '#f0f0f0' : '#525252'};`}
        onmouseover={!isProjects ? "this.style.color='#a3a3a3'" : ''}
        onmouseout={!isProjects ? "this.style.color='#525252'" : ''}
      >projects</a>

      <!-- Email icon -->
      <a
        href="mailto:qureshi.ayaz29@gmail.com"
        aria-label="Send email"
        class="nav-icon"
        style="color:#525252; display:flex; align-items:center; transition:color 0.15s;"
        onmouseover="this.style.color='#1D9E75'"
        onmouseout="this.style.color='#525252'"
      >
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>

      <!-- LinkedIn icon -->
      <a
        href="https://www.linkedin.com/in/ayazqureshi29/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        class="nav-icon"
        style="color:#525252; display:flex; align-items:center; transition:color 0.15s;"
        onmouseover="this.style.color='#1D9E75'"
        onmouseout="this.style.color='#525252'"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </div>

  </div>
</nav>
